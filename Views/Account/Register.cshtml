@model BobMart.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6">
        <div class="card bg-card-custom border-secondary p-4 shadow">
            <h2 class="text-center text-primary-custom mb-4"><i class="fa-solid fa-user-plus"></i> Create Account</h2>
            <form asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="All" class="text-danger mb-3"></div>
                
                <div class="row">
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="FirstName" class="text-light mb-1"></label>
                        <input asp-for="FirstName" class="form-control" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col-md-6 form-group mb-3">
                        <label asp-for="LastName" class="text-light mb-1"></label>
                        <input asp-for="LastName" class="form-control" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Email" class="text-light mb-1"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Password" class="text-light mb-1"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="form-group mb-4">
                    <label asp-for="ConfirmPassword" class="text-light mb-1"></label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-block text-uppercase fw-bold">Register</button>
                </div>
            </form>
            <div class="mt-4 text-center">
                <p class="text-muted small">Already have an account? <a asp-action="Login" class="text-primary-custom text-decoration-none fw-bold">Login here</a></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
