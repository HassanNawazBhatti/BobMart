@model BobMart.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Log in";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card bg-card-custom border-secondary p-4 shadow">
            <h2 class="text-center text-primary-custom mb-4"><i class="fa-solid fa-right-to-bracket"></i> Login</h2>
            <form asp-route-returnurl="@ViewData["ReturnUrl"]" method="post">
                <div asp-validation-summary="All" class="text-danger"></div>
                <div class="form-group mb-3">
                    <label asp-for="Email" class="text-light mb-1"></label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="form-group mb-3">
                    <label asp-for="Password" class="text-light mb-1"></label>
                    <input asp-for="Password" class="form-control" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="form-group mb-4">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label asp-for="RememberMe" class="form-check-label text-light">@Html.DisplayNameFor(m => m.RememberMe)</label>
                    </div>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-primary btn-block text-uppercase fw-bold">Log in</button>
                </div>
            </form>
            <div class="mt-4 text-center">
                <p class="text-muted small">Don't have an account? <a asp-action="Register" class="text-primary-custom text-decoration-none fw-bold">Register here</a></p>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
