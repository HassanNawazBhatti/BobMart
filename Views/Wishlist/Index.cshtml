@model BobMart.Models.Wishlist

@{
    ViewData["Title"] = "My Wishlist";
}

<h2 class="text-primary-custom mb-4 border-bottom border-secondary pb-2"><i class="fa-solid fa-heart"></i> My Wishlist</h2>

@if (Model.Items.Any())
{
    <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4">
        @foreach (var item in Model.Items)
        {
            <div class="col">
                <div class="card h-100 shadow-sm bg-card-custom border-secondary">
                    <img src="@item.Product?.ImageUrl" class="card-img-top" alt="@item.Product?.Name" style="height: 250px; object-fit: cover;">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title text-light mb-1">@item.Product?.Name</h5>
                        <p class="text-primary-custom fw-bold">Rs. @item.Product?.Price.ToString("0.00")</p>
                        
                        <div class="mt-auto d-flex flex-column gap-2 pt-3 border-top border-secondary">
                            <form asp-action="MoveToCart" method="post">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-primary w-100 btn-sm"><i class="fa-solid fa-cart-plus"></i> Move to Cart</button>
                            </form>
                            <form asp-action="Remove" method="post">
                                <input type="hidden" name="id" value="@item.Id" />
                                <button type="submit" class="btn btn-outline-danger w-100 btn-sm"><i class="fa-solid fa-trash"></i> Remove</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="fa-solid fa-heart-crack fa-4x text-muted mb-3"></i>
        <h3 class="text-light">Your wishlist is empty</h3>
        <p class="text-muted mb-4">You haven't coveted any items yet.</p>
        <a asp-controller="Products" asp-action="Index" class="btn btn-primary">Discover Items</a>
    </div>
}
