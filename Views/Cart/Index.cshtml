@model BobMart.ViewModels.CartViewModel

@{
    ViewData["Title"] = "Shopping Cart";
}

<h2 class="text-primary-custom mb-4 border-bottom border-secondary pb-2"><i class="fa-solid fa-cart-shopping"></i> Shopping Cart</h2>

@if (Model.Items.Any())
{
    <div class="row">
        <div class="col-md-8 mb-4">
            <div class="card bg-card-custom border-secondary">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-dark table-hover mb-0">
                            <thead class="border-secondary">
                                <tr>
                                    <th>Product</th>
                                    <th>Price</th>
                                    <th>Quantity</th>
                                    <th>Total</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.Items)
                                {
                                    <tr class="align-middle">
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <img src="@item.Product?.ImageUrl" alt="@item.Product?.Name" style="width: 50px; height: 50px; object-fit: cover;" class="me-3 rounded">
                                                <span>@item.Product?.Name</span>
                                            </div>
                                        </td>
                                        <td>Rs. @item.Product?.Price.ToString("0.00")</td>
                                        <td>
                                            <form asp-action="UpdateQuantity" method="post" class="d-flex align-items-center">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <input type="number" name="quantity" value="@item.Quantity" min="1" max="@item.Product?.Stock" class="form-control form-control-sm me-2" style="width: 70px;" onchange="this.form.submit()" />
                                            </form>
                                        </td>
                                        <td class="fw-bold">Rs. @((item.Quantity * item.Product!.Price).ToString("0.00"))</td>
                                        <td>
                                            <form asp-action="RemoveFromCart" method="post">
                                                <input type="hidden" name="id" value="@item.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card bg-card-custom border-secondary shadow">
                <div class="card-body">
                    <h4 class="card-title text-light border-bottom border-secondary pb-3 mb-3">Order Summary</h4>
                    <div class="d-flex justify-content-between mb-2 text-light">
                        <span>Subtotal</span>
                        <span>Rs. @Model.SubTotal.ToString("0.00")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-3 text-light pb-3 border-bottom border-secondary">
                        <span>Shipping</span>
                        <span>Rs. @Model.Shipping.ToString("0.00")</span>
                    </div>
                    <div class="d-flex justify-content-between mb-4">
                        <span class="h5 text-light fw-bold">Total</span>
                        <span class="h5 text-primary-custom fw-bold">Rs. @Model.Total.ToString("0.00")</span>
                    </div>
                    <a asp-controller="Checkout" asp-action="Index" class="btn btn-primary w-100 btn-lg text-uppercase fw-bold"><i class="fa-solid fa-lock"></i> Proceed to Checkout</a>
                </div>
            </div>
        </div>
    </div>
}
else
{
    <div class="text-center py-5">
        <i class="fa-solid fa-cart-arrow-down fa-4x text-muted mb-3"></i>
        <h3 class="text-light">Your cart is empty</h3>
        <p class="text-muted mb-4">Looks like you haven't added any dark items yet.</p>
        <a asp-controller="Products" asp-action="Index" class="btn btn-primary">Start Shopping</a>
    </div>
}
