@{
    ViewData["Title"] = "Order Successful";
}

<div class="container text-center py-5">
    <div class="card bg-card-custom border-success p-5 shadow mx-auto" style="max-width: 600px;">
        <i class="fa-solid fa-circle-check fa-5x text-success mb-4"></i>
        <h2 class="text-light mb-3">Order Placed Successfully!</h2>
        <p class="text-muted mb-4">Thank you for your purchase. Your order number is <strong>#@ViewBag.OrderId</strong>.</p>
        <p class="text-light mb-5">We will notify you once your order has been shipped into the darkness.</p>
        <div class="d-flex justify-content-center gap-3">
            <a asp-controller="Orders" asp-action="Details" asp-route-id="@ViewBag.OrderId" class="btn btn-outline-light">View Order</a>
            <a asp-controller="Products" asp-action="Index" class="btn btn-primary">Continue Shopping</a>
        </div>
    </div>
</div>
