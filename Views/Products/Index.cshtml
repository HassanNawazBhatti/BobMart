@model IEnumerable<BobMart.Models.Product>

@{
    ViewData["Title"] = "Shop";
}

<h2 class="text-primary-custom mb-4 border-bottom border-secondary pb-2"><i class="fa-solid fa-store"></i> All Products</h2>

<div class="row mb-4">
    <div class="col-md-12">
        <div class="card bg-card-custom border-secondary p-3">
            <form asp-action="Index" method="get" class="row g-3 align-items-center">
                <div class="col-md-4">
                    <input type="text" name="searchString" value="@ViewData["CurrentFilter"]" class="form-control" placeholder="Search products..." />
                </div>
                <div class="col-md-3">
                    <select name="categoryId" class="form-select">
                        <option value="">All Categories</option>
                        @foreach (var cat in ViewBag.Categories)
                        {
                            var isSelected = (ViewData["CategoryId"] as int?) == cat.Id ? "selected" : "";
                            <!option value="@cat.Id" @isSelected>@cat.Name</!option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <select name="sortOrder" class="form-select">
                        <!option value="newest" @((ViewData["SortOrder"] as string) == "newest" ? "selected" : "")>Newest</!option>
                        <!option value="price_asc" @((ViewData["SortOrder"] as string) == "price_asc" ? "selected" : "")>Price: Low to High</!option>
                        <!option value="price_desc" @((ViewData["SortOrder"] as string) == "price_desc" ? "selected" : "")>Price: High to Low</!option>
                        <!option value="rating" @((ViewData["SortOrder"] as string) == "rating" ? "selected" : "")>Top Rated</!option>
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Filter</button>
                </div>
            </form>
        </div>
    </div>
</div>

@if (!Model.Any())
{
    <div class="alert bg-card-custom border-secondary text-light">No products found matching your criteria.</div>
}
else
{
    var groupedProducts = Model.GroupBy(p => p.Category?.Name ?? "Uncategorized").OrderBy(g => g.Key);
    
    foreach (var group in groupedProducts)
    {
        <h3 class="text-light mt-5 mb-3 border-bottom border-secondary pb-2">@group.Key</h3>
        <div class="row row-cols-1 row-cols-md-3 row-cols-lg-4 g-4 mb-4">
            @foreach (var item in group)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm bg-card-custom border-secondary">
                        <div class="product-image-container">
                            <img src="@item.ImageUrl" class="card-img-top" alt="@item.Name" style="height: 250px; object-fit: cover;">
                            <div class="product-overlay">
                                <div class="rating">
                                    @for(int i = 0; i < Math.Round(item.Rating); i++) { <i class="fa-solid fa-star"></i> }
                                </div>
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-primary btn-sm rounded-pill px-4 py-2 text-uppercase fw-bold shadow">Details</a>
                            </div>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title text-light mb-1">@item.Name</h5>
                            <p class="card-text text-muted small flex-grow-1 text-truncate-1 mb-0">@item.Description</p>
                            <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top border-secondary">
                                <span class="fw-bold text-primary-custom h5 mb-0">Rs. @item.Price.ToString("0.00")</span>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
}
